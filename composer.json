{
    "name": "searchology/searchology-php",
    "description": "Official PHP SDK for the Searchology API — turn natural language search queries into structured JSON",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "searchology",
        "nlp",
        "natural-language",
        "search",
        "query-parser",
        "ai-search",
        "structured-search"
    ],
    "authors": [
        {
            "name": "Searchology",
            "email": "inspireupliftabdullah@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Searchology\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Searchology\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}